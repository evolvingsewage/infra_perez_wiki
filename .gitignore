# Terraform state must never be committed as it can contain secret values in
# plaintext regardless of `sensitive = true` in HCL. State lives in remote,
# encrypted backends (S3+KMS for AWS-touching config, Azure Storage for
# Azure-touching config), set up once via bootstrap/.
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
crash.log
crash.*.log

# Local variable files may contain secrets during manual testing 
*.tfvars
*.tfvars.json
!example.tfvars

# Plan output can contain sensitive values
*.tfplan
*.plan

# keys i've generated for manual testing
*_key
*_key.pub
id_*
throwaway_key*
jenkins_deploy_key*

# OS/editor cruft
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
